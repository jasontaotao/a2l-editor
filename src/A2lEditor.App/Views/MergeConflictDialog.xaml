<Window x:Class="A2lEditor.App.Views.MergeConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge Conflict Review" Height="500" Width="650"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="8">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Review changes before merging:"
                   FontWeight="SemiBold" Margin="0,0,0,6" />

        <!-- Summary -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,4" Margin="0,0,0,6">
            <TextBlock x:Name="SummaryBlock" Text="Loading..." />
        </Border>

        <!-- Change list -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
            <ItemsControl x:Name="ChangeList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="4,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          IsChecked="{Binding Accepted}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0" />

                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding KindLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding KindColor}"
                                           Margin="0,0,8,0" />

                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="{Binding Title}"
                                           FontWeight="Medium" />

                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                           Text="{Binding Details}"
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom bar -->
        <DockPanel DockPanel.Dock="Bottom">
            <Button Content="Accept Selected" Click="OnAccept" Padding="16,4"
                    DockPanel.Dock="Left" Margin="0,0,6,0" IsDefault="True" />
            <Button Content="Cancel" Click="OnCancel" Padding="16,4"
                    DockPanel.Dock="Right" IsCancel="True" />
        </DockPanel>
    </DockPanel>
</Window>
