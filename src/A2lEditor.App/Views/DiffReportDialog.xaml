<Window x:Class="A2lEditor.App.Views.DiffReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A2L Diff Report" Height="550" Width="780"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="8">
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Margin="0,0,0,6">
            <Label Content="Baseline:" />
            <TextBox x:Name="BaselinePathBox" Width="250" IsReadOnly="True" />
            <Button Content="Browse..." Click="OnSelectBaseline" Padding="6,2" />
            <Separator />
            <Label Content="Compared:" />
            <TextBox x:Name="ComparedPathBox" Width="250" IsReadOnly="True" />
            <Button Content="Browse..." Click="OnSelectCompared" Padding="6,2" />
            <Separator />
            <Button Content="Compare" Click="OnCompare" Padding="12,2" IsDefault="True" />
        </ToolBar>

        <!-- Summary -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,4" Margin="0,0,0,6">
            <TextBlock x:Name="SummaryBlock" Text="Select two .a2l files and click Compare."
                       FontWeight="SemiBold" />
        </Border>

        <!-- Report -->
        <Border BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="ReportBox"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         Padding="8"
                         BorderThickness="0"
                         Text="" />
            </ScrollViewer>
        </Border>

        <!-- Bottom bar -->
        <DockPanel DockPanel.Dock="Bottom">
            <Button Content="Save Merged..." Click="OnSaveMerged" Padding="12,2" DockPanel.Dock="Left" Margin="0,0,6,0" />
            <Button Content="Copy Report" Click="OnCopyReport" Padding="12,2" DockPanel.Dock="Left" />
            <Button Content="Close" Click="OnClose" Padding="12,2" DockPanel.Dock="Right" IsCancel="True" />
        </DockPanel>
    </DockPanel>
</Window>
