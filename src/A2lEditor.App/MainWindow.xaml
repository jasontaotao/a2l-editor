<Window x:Class="A2lEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:A2lEditor.App.Controls"
        xmlns:local="clr-namespace:A2lEditor.App"
        Title="{Binding Title}" Height="600" Width="900"
        AllowDrop="True"
        DragEnter="OnDragEnter"
        DragOver="OnDragOver"
        DragLeave="OnDragLeave"
        Drop="OnDrop">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="OnNew" />
        <CommandBinding Command="ApplicationCommands.Open" Executed="OnOpen" />
        <CommandBinding Command="ApplicationCommands.Save" Executed="OnSave" CanExecute="OnSave_CanExecute" />
        <CommandBinding Command="ApplicationCommands.SaveAs" Executed="OnSaveAs" CanExecute="OnSaveAs_CanExecute" />
        <CommandBinding Command="ApplicationCommands.Undo" Executed="OnUndo" />
        <CommandBinding Command="ApplicationCommands.Redo" Executed="OnRedo" />
        <CommandBinding Command="ApplicationCommands.Cut" Executed="OnCut" />
        <CommandBinding Command="ApplicationCommands.Copy" Executed="OnCopy" />
        <CommandBinding Command="ApplicationCommands.Paste" Executed="OnPaste" />
        <CommandBinding Command="ApplicationCommands.Find" Executed="OnFind" />
        <CommandBinding Command="NavigationCommands.IncreaseZoom" Executed="OnZoomIn" />
        <CommandBinding Command="NavigationCommands.DecreaseZoom" Executed="OnZoomOut" />
        <CommandBinding Command="{x:Static local:AppCommands.ResetZoom}" Executed="OnResetZoom" />
        <CommandBinding Command="ApplicationCommands.Help" Executed="OnAbout" />
        <CommandBinding Command="{x:Static local:AppCommands.ValidateFile}" Executed="OnValidate" />
        <CommandBinding Command="{x:Static local:AppCommands.FormatFile}" Executed="OnFormat" />
        <CommandBinding Command="{x:Static local:AppCommands.ExitFile}" Executed="OnExit" />
        <CommandBinding Command="{x:Static local:AppCommands.ApplyMap}" Executed="OnApplyMap" />
        <CommandBinding Command="{x:Static local:AppCommands.DiffFiles}" Executed="OnDiffFiles" />
        <CommandBinding Command="{x:Static local:AppCommands.ImportFromExcel}" Executed="OnImportFromExcel" />
    </Window.CommandBindings>
    <Border x:Name="DropTargetBorder" BorderBrush="Transparent" BorderThickness="2" AllowDrop="True">
    <DockPanel>
        <Menu x:Name="MainMenu" DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="ApplicationCommands.New" />
                <MenuItem Header="_Open..." Command="ApplicationCommands.Open" InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save" Command="ApplicationCommands.Save" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="ApplicationCommands.SaveAs" />
                <Separator />
                <MenuItem Header="_Recent Files" Name="RecentFilesMenu" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding FullPath}"/>
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Menu}}"/>
                            <Setter Property="CommandParameter" Value="{Binding FullPath}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="_Clear Recent" Command="{Binding ClearRecentCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{x:Static local:AppCommands.ExitFile}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="Cu_t" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X" />
                <MenuItem Header="_Copy" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V" />
                <Separator />
                <MenuItem Header="_Find..." Command="ApplicationCommands.Find" InputGestureText="Ctrl+F" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Command="NavigationCommands.IncreaseZoom" InputGestureText="Ctrl++" />
                <MenuItem Header="Zoom _Out" Command="NavigationCommands.DecreaseZoom" InputGestureText="Ctrl+-" />
                <MenuItem Header="_Reset Zoom" Command="{x:Static local:AppCommands.ResetZoom}" InputGestureText="Ctrl+0" />
                <Separator />
                <MenuItem Header="Toggle _Tree" Name="ToggleTreeMenuItem" IsCheckable="True" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Validate" Command="{x:Static local:AppCommands.ValidateFile}" InputGestureText="F5" />
                <MenuItem Header="_Format" Command="{x:Static local:AppCommands.FormatFile}" InputGestureText="F8" />
                <Separator />
                <MenuItem Header="_Apply MAP..." Command="{x:Static local:AppCommands.ApplyMap}" />
                <Separator />
                <MenuItem Header="_Diff Files..." Command="{x:Static local:AppCommands.DiffFiles}" />
                <MenuItem Header="_Import from Excel..." Command="{x:Static local:AppCommands.ImportFromExcel}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="ApplicationCommands.Help" />
            </MenuItem>
        </Menu>
        <ToolBar DockPanel.Dock="Top">
            <Button Content="打开" Command="{Binding OpenCommand}" x:Name="OpenButton"/>
            <Button Content="保存" Command="{Binding SaveCommand}" x:Name="SaveButton"/>
            <Separator/>
            <TextBlock Text="{Binding ModuleSummary}" VerticalAlignment="Center" Margin="6,0"/>
            <TextBlock Text="{Binding RecentFilesStatusMessage}" VerticalAlignment="Center" Margin="12,0"
                       Foreground="DarkOrange" FontStyle="Italic"/>
        </ToolBar>
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage}"/>
            <TextBlock Text=" ● " Visibility="{Binding IsDirty, Converter={x:Static ctl:BoolToVisibilityConverter.Instance}}"/>
        </StatusBar>
        <ctl:ErrorListPanel DockPanel.Dock="Bottom"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TreeView Grid.Column="0" x:Name="ModuleTree"
                      SelectedItemChanged="ModuleTree_SelectedItemChanged"/>
            <ctl:A2lTextEditor Grid.Column="1"
                               x:Name="TextEditor"
                               Text="{Binding RawText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               IsDirty="{Binding IsDirty, Mode=TwoWay}"/>
        </Grid>
    </DockPanel>
    </Border>
</Window>